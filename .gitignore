# .gitignore (root) — Globales que NUNCA deben subirse

# opencode (local, no versionar)
.opencode/sessions.db
.opencode/sessions*db
.opencode/sessions.db-shm
.opencode/sessions.db-wal
.opencode/worktrees/
.opencode/worktrees.db
.opencode/worktrees.log
.opencode/node_modules/
session-ses_*.md

# ── Secrets y claves (NUNCA en el repo) ──
**/*.key
**/*.pem
**/*.crt
**/*.priv
**/.age/poc-openwrt-privkey.txt
**/.age/keys*.txt
.envrc

# ── Archivos de entorno (solo .env.public puede subirse) ──
.env
**/.env
**/.env.local
**/.env.*.local

# ── OpenWRT build artifacts ──
openwrt-builder/
*.img
*.bin
*.manifest
sha256sums*
downloads/
staging_dir/
build_dir/
tmp/
logs/

# ── Config overlay generado ──
config/overlay/

# ── Secrets temporales generados por scripts ──
/tmp/secrets-*.yaml

# ── IDEs y editors ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──
.DS_Store
Thumbs.db

# ── Python ──
__pycache__/
*.pyc
.pytest_cache/

# ── Node ──
node_modules/
