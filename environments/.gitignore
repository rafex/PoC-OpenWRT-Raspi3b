# Solo permitir archivos encryptados y .env.public
# NUNCA permitir .yaml o .yml sin encryptar, ni .env sin extensión .public

# Bloquear .env sin sufijo (pueden contener secrets)
.env

# Permitir explícitamente
!.env.public
!secrets.enc.yaml
!secrets.enc.yml

# Bloquear TODO lo demás con extensión de config
*.yaml
*.yml
*.json
*.toml
*.ini

# Permitir solo los encryptados
!*.enc.yaml
!*.enc.yml

*.tmp